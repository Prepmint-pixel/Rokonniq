# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@host:3306/rokonniq

# For seed-plans.mjs (separate from DATABASE_URL)
DB_HOST=your-db-host
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=rokonniq

# ─── Auth ─────────────────────────────────────────────────────
JWT_SECRET=your-random-32-char-secret-here
OAUTH_SERVER_URL=https://your-oauth-provider.com
OWNER_OPEN_ID=your-open-id
VITE_APP_ID=rokonniq
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com

# ─── App URLs ─────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
VITE_FRONTEND_URL=https://rokonniq.io

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Gmail OAuth ──────────────────────────────────────────────
GMAIL_CLIENT_ID=your-gmail-client-id
GMAIL_CLIENT_SECRET=your-gmail-client-secret
# Redirect URI to register in Google Cloud Console:
# https://rokonniq.io/api/gmail/callback

# ─── Google Wallet ────────────────────────────────────────────
# From: western-lambda-460900-r2-46453318e579.json
GOOGLE_WALLET_PROJECT_ID=western-lambda-460900-r2
GOOGLE_WALLET_CLIENT_EMAIL=google-wallet-service@western-lambda-460900-r2.iam.gserviceaccount.com
# Paste the private_key value from the JSON file (keep the \n escape sequences)
GOOGLE_WALLET_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Analytics (optional) ─────────────────────────────────────
# VITE_ANALYTICS_ENDPOINT=https://your-umami-instance.com
# VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ─── Cloudinary (image & file storage) ───────────────────────
# Sign up free at cloudinary.com — 25GB included, no credit card needed
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
